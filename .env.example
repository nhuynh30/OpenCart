# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/opencart"

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

NODE_ENV="development"

# Stripe (use sk_test_... keys in dev/staging, sk_live_... only in production)
STRIPE_SECRET_KEY=
# From `stripe listen` locally, or the webhook endpoint's signing secret in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Public base URL of the app (used in emails and client-side links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (rate limiting, webhook idempotency, Stripe balance cache)
REDIS_URL="redis://localhost:6379"

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL="onboarding@resend.dev"

# AWS S3 (product image uploads)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
